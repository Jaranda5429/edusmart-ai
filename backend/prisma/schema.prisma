generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USUARIOS ────────────────────────────────────────────────────────────────

model User {
  id               Int       @id @default(autoincrement())
  nombre           String
  email            String    @unique
  password         String
  rol              Rol       @default(ESTUDIANTE)
  activo           Boolean   @default(true)
  // Membresía (solo profesores)
  membresiaActiva  Boolean   @default(false)
  membresiaTipo    String?   // "mensual" | "anual"
  membresiaVence   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relaciones
  periodos          Periodo[]
  pagos             Pago[]
  inscripciones     Inscripcion[]
  entregas          Entrega[]
  respuestasForo    RespuestaForo[]
  mensajes          Mensaje[]
  publicacionesForo PublicacionForo[]
  comentariosPub    ComentarioPub[]
  notificaciones    Notificacion[]
}

enum Rol {
  ADMIN
  PROFESOR
  ESTUDIANTE
}

// ─── MEMBRESÍA / PAGOS ───────────────────────────────────────────────────────

model Pago {
  id        Int      @id @default(autoincrement())
  userId    Int
  tipo      String   // "mensual" | "anual"
  monto     Int      // en pesos colombianos
  estado    String   @default("aprobado")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── ESTRUCTURA ACADÉMICA ────────────────────────────────────────────────────

model Periodo {
  id         Int      @id @default(autoincrement())
  nombre     String
  fechaInicio DateTime?
  fechaFin   DateTime?
  activo     Boolean  @default(true)
  profesorId Int
  createdAt  DateTime @default(now())

  profesor User    @relation(fields: [profesorId], references: [id], onDelete: Cascade)
  grados   Grado[]
}

model Grado {
  id        Int      @id @default(autoincrement())
  nombre    String
  periodoId Int
  createdAt DateTime @default(now())

  periodo  Periodo   @relation(fields: [periodoId], references: [id], onDelete: Cascade)
  materias Materia[]
}

model Materia {
  id        Int      @id @default(autoincrement())
  nombre    String
  icono     String   @default("📖")
  codigo    String?  @unique
  gradoId   Int
  createdAt DateTime @default(now())

  grado         Grado         @relation(fields: [gradoId], references: [id], onDelete: Cascade)
  actividades   Actividad[]
  inscripciones Inscripcion[]
  forosTema     ForoTema[]
}

// ─── INSCRIPCIONES ───────────────────────────────────────────────────────────

model Inscripcion {
  id           Int      @id @default(autoincrement())
  estudianteId Int
  materiaId    Int
  createdAt    DateTime @default(now())

  estudiante User    @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  materia    Materia @relation(fields: [materiaId], references: [id], onDelete: Cascade)

  @@unique([estudianteId, materiaId])
}

// ─── ACTIVIDADES ─────────────────────────────────────────────────────────────

model Actividad {
  id           Int      @id @default(autoincrement())
  titulo       String
  descripcion  String?
  fechaInicio  DateTime?
  fechaLimite  DateTime
  foroActivo   Boolean  @default(false)
  soloForo     Boolean  @default(false)
  foroTema     String?
  materiaId    Int
  createdAt    DateTime @default(now())

  materia    Materia     @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  contenidos Contenido[]
  entregas   Entrega[]
  foro       Foro?
}

model Contenido {
  id          Int      @id @default(autoincrement())
  tipo        String   // archivo | video_link | explicacion | quiz | link | imagen
  label       String
  icono       String   @default("📄")
  texto       String?
  url         String?
  nombre      String?
  actividadId Int
  createdAt   DateTime @default(now())

  actividad Actividad  @relation(fields: [actividadId], references: [id], onDelete: Cascade)
  preguntas Pregunta[]
}

model Pregunta {
  id          Int      @id @default(autoincrement())
  texto       String
  opciones    String[]
  correcta    Int
  contenidoId Int

  contenido Contenido @relation(fields: [contenidoId], references: [id], onDelete: Cascade)
}

// ─── ENTREGAS ────────────────────────────────────────────────────────────────

model Entrega {
  id           Int      @id @default(autoincrement())
  texto        String?
  archivoUrl   String?
  archivoNombre String?
  entregado    Boolean  @default(false)
  calificacion Float?
  estudianteId Int
  actividadId  Int
  createdAt    DateTime @default(now())

  estudiante User      @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  actividad  Actividad @relation(fields: [actividadId], references: [id], onDelete: Cascade)

  @@unique([estudianteId, actividadId])
}

// ─── FORO (de actividad, legacy) ─────────────────────────────────────────────

model Foro {
  id          Int      @id @default(autoincrement())
  tema        String
  fechaLimite DateTime?
  actividadId Int      @unique
  createdAt   DateTime @default(now())

  actividad  Actividad       @relation(fields: [actividadId], references: [id], onDelete: Cascade)
  respuestas RespuestaForo[]
}

model RespuestaForo {
  id           Int      @id @default(autoincrement())
  respuesta    String?
  estudianteId Int
  foroId       Int
  createdAt    DateTime @default(now())

  estudiante  User         @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  foro        Foro         @relation(fields: [foroId], references: [id], onDelete: Cascade)
  comentarios Comentario[]

  @@unique([estudianteId, foroId])
}

model Comentario {
  id              Int      @id @default(autoincrement())
  texto           String
  autorNombre     String
  respuestaForoId Int
  createdAt       DateTime @default(now())

  respuestaForo RespuestaForo @relation(fields: [respuestaForoId], references: [id], onDelete: Cascade)
}

// ─── FORO INDEPENDIENTE (ligado a Materia) ───────────────────────────────────

model ForoTema {
  id          Int      @id @default(autoincrement())
  titulo      String
  descripcion String?
  fechaLimite DateTime?
  materiaId   Int
  createdAt   DateTime @default(now())

  materia       Materia           @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  publicaciones PublicacionForo[]
}

model PublicacionForo {
  id           Int      @id @default(autoincrement())
  texto        String
  estudianteId Int
  foroTemaId   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  estudiante  User            @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  foroTema    ForoTema        @relation(fields: [foroTemaId], references: [id], onDelete: Cascade)
  comentarios ComentarioPub[]
}

model ComentarioPub {
  id            Int      @id @default(autoincrement())
  texto         String
  autorId       Int
  autorNombre   String
  publicacionId Int
  createdAt     DateTime @default(now())

  autor       User            @relation(fields: [autorId], references: [id], onDelete: Cascade)
  publicacion PublicacionForo @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
}

// ─── NOTIFICACIONES (de evento) ──────────────────────────────────────────────

model Notificacion {
  id        Int      @id @default(autoincrement())
  userId    Int
  tipo      String
  titulo    String
  mensaje   String
  leida     Boolean  @default(false)
  ruta      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── MENSAJES IA ─────────────────────────────────────────────────────────────

model Mensaje {
  id        Int      @id @default(autoincrement())
  contenido String
  userId    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}